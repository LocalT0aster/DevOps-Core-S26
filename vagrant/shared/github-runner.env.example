# Copy this file to shared/github-runner.env and fill in the values before
# running:
#   vagrant provision github-runner --provision-with github-runner-register

GH_RUNNER_URL="https://github.com/OWNER/REPOSITORY"
GH_RUNNER_TOKEN="REPLACE_WITH_EPHEMERAL_REGISTRATION_TOKEN"

# Optional overrides
GH_RUNNER_NAME="github-runner-s26"
GH_RUNNER_LABELS="self-hosted,linux,vagrant"
GH_RUNNER_GROUP="Default"
GH_RUNNER_WORKDIR="_work"
# GH_RUNNER_VERSION="PIN_A_KNOWN_RUNNER_VERSION"
# GH_RUNNER_DISABLE_UPDATE="true"
